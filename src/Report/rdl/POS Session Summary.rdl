                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>="Session No: " &amp; First(Fields!SessionNo.Value, "DataSet_Result") &amp; vbCrLf &amp;
"Store: " &amp; First(Fields!StoreCode.Value, "DataSet_Result") &amp; vbCrLf &amp;
"Terminal: " &amp; First(Fields!TerminalCode.Value, "DataSet_Result") &amp; vbCrLf &amp;
"User: " &amp; First(Fields!UserID.Value, "DataSet_Result")</Value>
                                  <Style>
                                    <FontFamily>Segoe UI</FontFamily>
