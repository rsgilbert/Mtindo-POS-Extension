                    <TablixCell>
                      <CellContents>
                        <Textbox Name="SessionMetaRightBox">
                          <CanGrow>true</CanGrow>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>="Status: " &amp; First(Fields!StatusText.Value, "DataSet_Result") &amp; vbCrLf &amp;
"Opened: " &amp; IIF(IsNothing(First(Fields!OpenedAt.Value, "DataSet_Result")), "", Format(First(Fields!OpenedAt.Value, "DataSet_Result"), "dd/MM/yyyy HH:mm")) &amp; vbCrLf &amp;
"Closed: " &amp; IIF(IsNothing(First(Fields!ClosedAt.Value, "DataSet_Result")), "", Format(First(Fields!ClosedAt.Value, "DataSet_Result"), "dd/MM/yyyy HH:mm")) &amp; vbCrLf &amp;
"Supervisor: " &amp; First(Fields!ClosedBySupervisor.Value, "DataSet_Result")</Value>
