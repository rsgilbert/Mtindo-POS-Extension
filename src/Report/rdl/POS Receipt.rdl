                </TablixRow>
                <!-- Total Row -->
                <TablixRow>
                  <Height>0.28in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="PaySummary">
                          <CanGrow>true</CanGrow>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>="Cash: " &amp; Format(IIF(IsNothing(Fields!CashAmount.Value), 0, Fields!CashAmount.Value), "#,##0.00") &amp; "  Card: " &amp; Format(IIF(IsNothing(Fields!CardAmount.Value), 0, Fields!CardAmount.Value), "#,##0.00") &amp; "  Mobile: " &amp; Format(IIF(IsNothing(Fields!MobileAmount.Value), 0, Fields!MobileAmount.Value), "#,##0.00")</Value>
                                  <Style>
                                    <FontFamily>Segoe UI</FontFamily>
                                    <FontSize>7pt</FontSize>
                                    <Color>#666666</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <Style>
                            <PaddingLeft>4pt</PaddingLeft>
                            <PaddingTop>4pt</PaddingTop>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="TotalLabel">
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>TOTAL</Value>
                                  <Style>
                                    <FontFamily>Segoe UI</FontFamily>
                                    <FontSize>10pt</FontSize>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                              </TextRuns>
